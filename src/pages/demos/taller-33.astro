---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    number: '01',
    name: 'Corte',
    description: 'Consulta, lavado y un corte adaptado a tu estilo.',
    duration: '45 min',
    price: '22 €',
  },
  {
    number: '02',
    name: 'Corte + barba',
    description: 'Corte completo y arreglo de barba con acabado a navaja.',
    duration: '60 min',
    price: '32 €',
  },
  {
    number: '03',
    name: 'Ritual de barba',
    description: 'Toalla caliente, perfilado y cuidado final de la piel.',
    duration: '30 min',
    price: '18 €',
  },
];
---

<BaseLayout
  title="Taller 33 — Concepto interactivo de barbería"
  description="Demo ficticia y navegable de una web de barbería creada por Jordi Sánchez Web."
  canonicalPath="/demos/taller-33/"
  noindex
  hideHeader
  hideFooter
>
  <div class="demo-shell">
    <aside class="demo-notice" aria-label="Aviso sobre esta demostración">
      <p><strong>Concepto demostrativo</strong> · Taller 33 es un negocio ficticio</p>
      <a href="/ejemplos/">Volver a Jordi Sánchez Web <span aria-hidden="true">↗</span></a>
    </aside>

    <header class="demo-header">
      <a class="demo-brand" href="#inicio" aria-label="Taller 33, volver al inicio">
        Taller <span>33</span>
      </a>
      <nav aria-label="Navegación de la demo">
        <a href="#servicios">Servicios</a>
        <a href="#taller">El taller</a>
        <a href="#horarios">Horarios</a>
        <a class="nav-booking" href="#reservar">Reservar</a>
      </nav>
    </header>

    <section class="demo-hero" id="inicio" aria-labelledby="demo-title">
      <div class="hero-copy">
        <p class="kicker">Barbería contemporánea · Barcelona</p>
        <h1 id="demo-title">Corte limpio.<br /><em>Sin esperas.</em></h1>
        <p class="hero-intro">
          Barbería de barrio con cita previa, atención directa y el tiempo que necesita cada corte.
        </p>
        <a class="demo-button demo-button--accent" href="#reservar">Reservar hora</a>
      </div>

      <div class="hero-poster" aria-hidden="true">
        <div class="poster-frame">
          <div class="poster-art">
            <span></span>
            <i></i>
          </div>
          <p>Barcelona · 08012</p>
        </div>
      </div>

      <p class="hero-services" aria-hidden="true">Corte · Barba · Ritual</p>
    </section>

    <section class="demo-section services" id="servicios" aria-labelledby="services-title">
      <div class="section-heading">
        <p class="kicker">01 · Servicios</p>
        <h2 id="services-title">Lo justo.<br />Bien hecho.</h2>
        <p>
          Una carta corta, precios claros y tiempo reservado solo para ti. Los importes son orientativos para esta demostración.
        </p>
      </div>

      <ol class="service-list">
        {services.map((service) => (
          <li>
            <p class="service-number">{service.number}</p>
            <div>
              <h3>{service.name}</h3>
              <p>{service.description}</p>
            </div>
            <p class="service-time">{service.duration}</p>
            <p class="service-price">{service.price}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="story" id="taller" aria-labelledby="story-title">
      <div class="story-art" aria-hidden="true">
        <span class="story-circle"></span>
        <span class="story-line story-line--one"></span>
        <span class="story-line story-line--two"></span>
      </div>
      <div class="story-copy">
        <p class="kicker">02 · El taller</p>
        <h2 id="story-title">Un sillón.<br /><em>Todo el tiempo.</em></h2>
        <p>
          Sin colas ni prisas. Cada cita bloquea el tiempo necesario para escuchar, cortar y terminar bien. Esa es toda la filosofía.
        </p>
        <dl>
          <div>
            <dt>1</dt>
            <dd>Cliente por turno</dd>
          </div>
          <div>
            <dt>45</dt>
            <dd>Minutos por corte</dd>
          </div>
          <div>
            <dt>0</dt>
            <dd>Tiempo de espera</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="booking" id="reservar" aria-labelledby="booking-title">
      <div class="booking-intro">
        <p class="kicker">03 · Reserva</p>
        <h2 id="booking-title">Tu hora,<br /><em>en tres pasos.</em></h2>
        <p>
          Prueba el flujo de reserva. Esta simulación no recoge datos ni crea una cita real.
        </p>
      </div>

      <form class="booking-form" id="demo-booking-form">
        <label for="demo-service">1. Elige servicio</label>
        <select id="demo-service" name="servicio" required>
          <option value="">Selecciona una opción</option>
          <option value="Corte">Corte · 45 min · 22 €</option>
          <option value="Corte + barba">Corte + barba · 60 min · 32 €</option>
          <option value="Ritual de barba">Ritual de barba · 30 min · 18 €</option>
        </select>

        <label for="demo-day">2. Elige día</label>
        <select id="demo-day" name="dia" required>
          <option value="">Selecciona un día</option>
          <option value="Martes">Martes</option>
          <option value="Miércoles">Miércoles</option>
          <option value="Jueves">Jueves</option>
          <option value="Viernes">Viernes</option>
        </select>

        <fieldset>
          <legend>3. Elige hora</legend>
          <div class="time-grid">
            {['10:00', '11:30', '16:00', '17:30', '19:00'].map((time) => (
              <label>
                <input type="radio" name="hora" value={time} required />
                <span>{time}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <button class="demo-button demo-button--light" type="submit">Simular reserva</button>
        <p
          class="booking-result"
          id="demo-booking-result"
          role="status"
          aria-live="polite"
          tabindex="-1"
        ></p>
      </form>
    </section>

    <section class="visit" id="horarios" aria-labelledby="visit-title">
      <div>
        <p class="kicker">04 · Visítanos</p>
        <h2 id="visit-title">Gràcia.<br />Barcelona.</h2>
      </div>
      <div class="visit-details">
        <div>
          <h3>Horario</h3>
          <p>Martes—viernes<br />10:00—20:00</p>
          <p>Sábado<br />09:00—15:00</p>
        </div>
        <div>
          <h3>Dirección de muestra</h3>
          <p>Carrer de la Mostra, 33<br />08012 Barcelona</p>
          <p class="fiction-note">Dirección ficticia para esta demo.</p>
        </div>
      </div>
    </section>

    <footer class="demo-footer">
      <a class="demo-brand" href="#inicio">Taller <span>33</span></a>
      <p>Concepto interactivo creado por <a href="/">Jordi Sánchez Web</a>.</p>
      <p>Negocio, precios, horarios y dirección ficticios.</p>
    </footer>

    <script>
      const bookingForm = document.querySelector<HTMLFormElement>('#demo-booking-form');
      const bookingResult = document.querySelector<HTMLElement>('#demo-booking-result');

      bookingForm?.addEventListener('submit', (event) => {
        event.preventDefault();

        const formData = new FormData(bookingForm);
        const service = formData.get('servicio');
        const day = formData.get('dia');
        const time = formData.get('hora');

        if (bookingResult && service && day && time) {
          bookingResult.textContent = `Vista previa: ${service} · ${day} · ${time}. En una web real, aquí confirmaríamos la cita.`;
          bookingResult.focus();
        }
      });
    </script>
  </div>
</BaseLayout>

<style>
  :global(html) {
    scroll-padding-top: 5rem;
  }

  :global(body) {
    background: #14110d;
  }

  :global(#contenido) {
    overflow: hidden;
  }

  .demo-shell {
    --demo-bg: #14110d;
    --demo-panel: #2b2620;
    --demo-paper: #f2ede4;
    --demo-muted: #a9a095;
    --demo-line: #514940;
    --demo-accent: #973f33;
    min-height: 100vh;
    background: var(--demo-bg);
    color: var(--demo-paper);
  }

  .demo-shell a {
    color: inherit;
  }

  .demo-notice {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 2rem;
    padding: 0.6rem clamp(1rem, 4vw, 3rem);
    background: var(--demo-paper);
    color: var(--demo-bg);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  .demo-notice a {
    font-weight: 750;
  }

  .demo-header,
  .demo-hero,
  .demo-section,
  .story,
  .booking,
  .visit,
  .demo-footer {
    width: min(100%, 90rem);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 5rem);
  }

  .demo-header {
    display: flex;
    min-height: 6rem;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-bottom: 1px solid var(--demo-line);
  }

  .demo-brand {
    display: inline-flex;
    gap: 0.55em;
    font-family: var(--serif);
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    font-weight: 650;
    letter-spacing: 0.2em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .demo-brand span {
    color: var(--demo-accent);
  }

  .demo-header nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
  }

  .demo-header nav a {
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .demo-header .nav-booking {
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--demo-paper);
  }

  .demo-hero {
    display: grid;
    min-height: min(50rem, calc(100vh - 8.75rem));
    gap: 3rem;
    align-items: center;
    padding-block: clamp(4.5rem, 9vw, 8rem) 2rem;
  }

  .kicker {
    color: var(--demo-muted);
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-copy h1,
  .demo-shell h2,
  .demo-shell h3 {
    color: var(--demo-paper);
  }

  .hero-copy h1 {
    max-width: 8.5ch;
    margin-top: 2rem;
    font-size: clamp(4.2rem, 10.5vw, 9.5rem);
    line-height: 0.82;
  }

  .hero-copy h1 em,
  .story h2 em,
  .booking h2 em {
    color: var(--demo-accent);
    font-weight: 430;
  }

  .hero-intro {
    max-width: 31rem;
    margin-top: 2.5rem;
    color: var(--demo-muted);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
  }

  .demo-button {
    display: inline-flex;
    min-height: 3.65rem;
    align-items: center;
    justify-content: center;
    margin-top: 2.5rem;
    padding: 0.9rem 1.5rem;
    border: 1px solid transparent;
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.13em;
    text-decoration: none;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .demo-button--accent {
    background: var(--demo-accent);
    color: #fff;
  }

  .demo-button--accent:hover {
    border-color: var(--demo-paper);
    background: transparent;
  }

  .hero-poster {
    display: grid;
    place-items: center;
  }

  .poster-frame {
    width: min(100%, 23rem);
    padding: clamp(1.4rem, 4vw, 2.5rem);
    background: var(--demo-panel);
    transform: rotate(1.5deg);
  }

  .poster-art {
    position: relative;
    display: grid;
    aspect-ratio: 0.86;
    place-items: center;
    overflow: hidden;
    background: var(--demo-accent);
  }

  .poster-art::before,
  .poster-art::after {
    position: absolute;
    right: 15%;
    left: 15%;
    height: 0.45rem;
    background: var(--demo-paper);
    content: '';
  }

  .poster-art::before {
    bottom: 17%;
  }

  .poster-art::after {
    bottom: 12%;
  }

  .poster-art span {
    width: 58%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--demo-bg);
  }

  .poster-art i {
    position: absolute;
    top: -10%;
    left: 12%;
    width: 1px;
    height: 120%;
    background: rgba(242, 237, 228, 0.5);
    transform: rotate(36deg);
  }

  .poster-frame > p {
    margin-top: 1.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-services {
    padding-top: 1.25rem;
    border-top: 1px solid var(--demo-line);
    color: var(--demo-muted);
    font-size: 0.65rem;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .demo-section,
  .story,
  .booking,
  .visit {
    padding-block: clamp(5rem, 10vw, 9rem);
    border-top: 1px solid var(--demo-line);
  }

  .section-heading {
    display: grid;
    gap: 2rem;
  }

  .section-heading h2,
  .story h2,
  .booking h2,
  .visit h2 {
    font-size: clamp(3.5rem, 8vw, 7rem);
  }

  .section-heading > p:last-child,
  .story-copy > p:not(.kicker),
  .booking-intro > p:not(.kicker) {
    max-width: 34rem;
    color: var(--demo-muted);
  }

  .service-list {
    margin: clamp(4rem, 8vw, 7rem) 0 0;
    padding: 0;
    border-top: 1px solid var(--demo-paper);
    list-style: none;
  }

  .service-list li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: start;
    padding-block: 2rem;
    border-bottom: 1px solid var(--demo-line);
  }

  .service-number,
  .service-time {
    color: var(--demo-muted);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .service-list h3 {
    font-size: clamp(2rem, 4vw, 3.3rem);
  }

  .service-list li > div > p {
    max-width: 30rem;
    margin-top: 0.8rem;
    color: var(--demo-muted);
    font-size: 0.9rem;
  }

  .service-time {
    display: none;
  }

  .service-price {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .story {
    display: grid;
    gap: clamp(3rem, 8vw, 8rem);
  }

  .story-art {
    position: relative;
    min-height: 30rem;
    overflow: hidden;
    background: var(--demo-accent);
  }

  .story-circle {
    position: absolute;
    top: 18%;
    left: 50%;
    width: 52%;
    aspect-ratio: 1;
    border: 1px solid var(--demo-paper);
    border-radius: 50%;
    transform: translateX(-50%);
  }

  .story-circle::before {
    position: absolute;
    inset: 18%;
    border-radius: inherit;
    background: var(--demo-bg);
    content: '';
  }

  .story-line {
    position: absolute;
    right: 12%;
    left: 12%;
    height: 1px;
    background: var(--demo-paper);
  }

  .story-line--one {
    bottom: 21%;
  }

  .story-line--two {
    bottom: 15%;
  }

  .story-copy {
    align-self: center;
  }

  .story-copy h2,
  .booking-intro h2 {
    margin-top: 1.5rem;
  }

  .story-copy > p:not(.kicker),
  .booking-intro > p:not(.kicker) {
    margin-top: 2rem;
  }

  .story dl {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin: 3rem 0 0;
    border-top: 1px solid var(--demo-line);
  }

  .story dl div {
    padding: 1.5rem 0.5rem 0 0;
  }

  .story dt {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
  }

  .story dd {
    margin: 0.65rem 0 0;
    color: var(--demo-muted);
    font-size: 0.62rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .booking {
    display: grid;
    gap: clamp(3.5rem, 8vw, 8rem);
    background: var(--demo-panel);
    background-clip: content-box;
  }

  .booking-intro,
  .booking-form {
    padding-inline: clamp(1.5rem, 4vw, 4rem);
  }

  .booking-intro {
    padding-top: clamp(3rem, 6vw, 5rem);
  }

  .booking-form {
    display: grid;
    gap: 1rem;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .booking-form > label,
  .booking-form legend {
    margin-top: 1rem;
    color: var(--demo-muted);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .booking-form select {
    width: 100%;
    min-height: 3.75rem;
    padding: 0.75rem 0;
    border: 0;
    border-bottom: 1px solid var(--demo-line);
    border-radius: 0;
    background: transparent;
    color: var(--demo-paper);
    font: inherit;
  }

  .booking-form select option {
    color: var(--demo-bg);
  }

  .booking-form fieldset {
    margin: 1rem 0 0;
    padding: 0;
    border: 0;
  }

  .time-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: 1rem;
  }

  .time-grid label {
    cursor: pointer;
  }

  .time-grid input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .time-grid span {
    display: grid;
    min-height: 3rem;
    place-items: center;
    border: 1px solid var(--demo-line);
    font-size: 0.75rem;
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .time-grid input:checked + span {
    border-color: var(--demo-accent);
    background: var(--demo-accent);
  }

  .time-grid input:focus-visible + span {
    outline: 2px solid var(--demo-paper);
    outline-offset: 3px;
  }

  .demo-button--light {
    width: 100%;
    background: var(--demo-paper);
    color: var(--demo-bg);
  }

  .demo-button--light:hover {
    border-color: var(--demo-paper);
    background: transparent;
    color: var(--demo-paper);
  }

  .booking-result {
    min-height: 3.5rem;
    color: #d9b4ab;
    font-size: 0.85rem;
  }

  .visit {
    display: grid;
    gap: 3rem;
  }

  .visit-details {
    display: grid;
    gap: 2rem;
  }

  .visit-details > div {
    padding-top: 1.5rem;
    border-top: 1px solid var(--demo-line);
  }

  .visit-details h3 {
    font-family: var(--sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .visit-details p {
    margin-top: 1rem;
    color: var(--demo-muted);
  }

  .visit-details .fiction-note {
    font-size: 0.7rem;
    font-style: italic;
  }

  .demo-footer {
    display: grid;
    gap: 1rem;
    padding-block: 2.5rem;
    border-top: 1px solid var(--demo-line);
    color: var(--demo-muted);
    font-size: 0.68rem;
  }

  .demo-footer .demo-brand {
    color: var(--demo-paper);
  }

  @media (max-width: 47.99rem) {
    .demo-notice {
      flex-direction: column;
    }

    .demo-header {
      min-height: 5rem;
    }

    .demo-header nav a:not(.nav-booking) {
      display: none;
    }

    .demo-hero {
      min-height: auto;
    }
  }

  @media (min-width: 48rem) {
    .demo-hero {
      grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.7fr);
    }

    .hero-services {
      grid-column: 1 / -1;
    }

    .section-heading {
      grid-template-columns: 0.35fr minmax(0, 0.8fr) minmax(18rem, 0.5fr);
      align-items: start;
    }

    .service-list li {
      grid-template-columns: 3.5rem minmax(0, 1fr) 6rem 5rem;
      align-items: center;
    }

    .service-time {
      display: block;
    }

    .story,
    .booking,
    .visit {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: center;
    }

    .time-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .visit-details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .demo-footer {
      grid-template-columns: minmax(12rem, 1fr) 1fr 1fr;
      align-items: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
