---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import barberiaDemo from '../assets/demos/barberia-concepto.png';
import peluqueriaDemo from '../assets/demos/peluqueria-concepto.png';
import esteticaDemo from '../assets/demos/estetica-concepto.png';

const projects = [
  {
    number: '01',
    type: 'Barbería',
    title: 'Taller 33',
    description: 'Una presencia directa y sobria, con la reserva siempre a un paso.',
    image: barberiaDemo,
    alt: 'Concepto de página web oscura y editorial para la barbería ficticia Taller 33',
    href: '/demos/taller-33/',
    status: 'Ver demo interactiva',
  },
  {
    number: '02',
    type: 'Peluquería',
    title: 'Llum',
    description: 'Un diseño luminoso para transmitir cuidado, oficio y cercanía.',
    image: peluqueriaDemo,
    alt: 'Concepto de página web clara para la peluquería ficticia Llum',
    status: 'Concepto visual',
  },
  {
    number: '03',
    type: 'Centro de estética',
    title: 'Calma',
    description: 'Información y tratamientos ordenados con una estética serena y precisa.',
    image: esteticaDemo,
    alt: 'Concepto de página web en tonos naturales para el centro de estética ficticio Calma',
    status: 'Concepto visual',
  },
];
---

<BaseLayout
  title="Conceptos de webs para negocios locales | Jordi Sánchez"
  description="Portfolio de desarrollo y conceptos de diseño web para barberías, peluquerías y centros de estética con reserva online."
  canonicalPath="/ejemplos/"
>
  <header class="page-intro container">
    <p class="eyebrow">Conceptos</p>
    <h1>Webs con personalidad para negocios con oficio.</h1>
    <div class="page-intro__footer">
      <p class="lede">
        Tres direcciones visuales para enseñar cómo puede verse un negocio local cuando su web cuenta bien lo que hace. Taller 33 ya puede recorrerse como demo; todas son propuestas ficticias, no trabajos realizados para clientes.
      </p>
      <p class="meta-line"><span>Barcelona</span><span>2026</span></p>
    </div>
  </header>

  <section class="portfolio-section" aria-labelledby="portfolio-heading">
    <div class="container portfolio-grid">
      <p class="eyebrow">Portfolio de desarrollo</p>
      <h2 id="portfolio-heading">Proyectos reales, producto y código.</h2>
      <div class="portfolio-copy">
        <p>
          Una selección de aplicaciones y webs en las que he trabajado como desarrollador full stack.
        </p>
        <a
          class="text-link"
          href="https://jordi-sanchez-portafolio.vercel.app/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Ver mi portfolio
        </a>
      </div>
    </div>
  </section>

  <section class="work-section" aria-label="Galería de conceptos web">
    <div class="container work-list">
      {projects.map((project, index) => (
        <article class="work-item">
          <div class="work-meta">
            <p>{project.number}</p>
            <p>{project.type}</p>
            <p>Concepto</p>
          </div>

          <figure>
            <Image
              src={project.image}
              alt={project.alt}
              widths={[560, 840, 1200, 1440]}
              sizes="(min-width: 82rem) 1200px, (min-width: 48rem) 88vw, 100vw"
              format="webp"
              quality={86}
              loading={index === 0 ? 'eager' : 'lazy'}
            />
            {project.href && (
              <a
                class="preview-link"
                href={project.href}
                aria-label={`Explorar la demo interactiva de ${project.title}`}
              >
                <span>Explorar demo <span aria-hidden="true">↗</span></span>
              </a>
            )}
          </figure>

          <div class="work-copy">
            <h2>{project.title}</h2>
            <p>{project.description}</p>
            {project.href ? (
              <a class="work-status" href={project.href}>{project.status} <span aria-hidden="true">↗</span></a>
            ) : (
              <span>{project.status}</span>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="examples-cta">
    <div class="container cta-grid">
      <p class="eyebrow">Tu proyecto</p>
      <h2>La siguiente puede ser la tuya.</h2>
      <div>
        <p>
          No se trata de elegir una plantilla. Hablamos de tu negocio y construyo la dirección adecuada para ti.
        </p>
        <a class="button button--accent" href="/#contacto">Hablemos de tu web</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .portfolio-section {
    padding-block: clamp(3.5rem, 7vw, 6rem);
    border-top: 1px solid var(--line);
    background: #eee9e0;
  }

  .portfolio-grid {
    display: grid;
    gap: 2rem;
  }

  .portfolio-grid h2 {
    max-width: 11ch;
    font-size: clamp(2.55rem, 5vw, 5rem);
  }

  .portfolio-copy > p {
    max-width: 31rem;
    color: var(--muted);
  }

  .portfolio-copy .text-link {
    margin-top: 2rem;
  }

  .work-section {
    padding-bottom: var(--section-space);
    border-top: 1px solid var(--line);
  }

  .work-list {
    display: grid;
  }

  .work-item {
    padding-block: clamp(3.5rem, 8vw, 7rem);
    border-bottom: 1px solid var(--line);
  }

  .work-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.25rem;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .work-meta p:nth-child(2) {
    text-align: center;
  }

  .work-meta p:last-child {
    text-align: right;
  }

  figure {
    position: relative;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #e8e1d6;
  }

  figure :global(img) {
    width: 100%;
    height: auto;
    transition: transform 500ms cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  .work-item:hover figure :global(img) {
    transform: scale(1.012);
  }

  .preview-link {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1rem;
    text-decoration: none;
  }

  .preview-link > span {
    padding: 0.75rem 0.9rem;
    background: var(--paper);
    color: var(--ink);
    font-size: 0.67rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .work-copy {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .work-copy h2 {
    font-size: clamp(2.6rem, 6vw, 5rem);
  }

  .work-copy > p {
    max-width: 34rem;
    color: var(--muted);
  }

  .work-copy > span,
  .work-status {
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.11em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .examples-cta {
    padding-block: var(--section-space);
    background: #eee9e0;
  }

  .cta-grid {
    display: grid;
    gap: 2rem;
  }

  .cta-grid h2 {
    max-width: 10ch;
  }

  .cta-grid > div > p {
    max-width: 31rem;
    color: var(--muted);
  }

  .cta-grid .button {
    margin-top: 2rem;
  }

  @media (min-width: 48rem) {
    .portfolio-grid {
      grid-template-columns: 0.25fr minmax(0, 0.9fr) minmax(20rem, 0.45fr);
      align-items: start;
    }

    .portfolio-grid .eyebrow {
      margin: 0;
    }

    .work-copy {
      grid-template-columns: minmax(12rem, 0.55fr) minmax(18rem, 0.35fr) minmax(8rem, 0.1fr);
      align-items: end;
    }

    .work-copy > span,
    .work-status {
      justify-self: end;
      padding-bottom: 0.35rem;
    }

    .cta-grid {
      grid-template-columns: 0.25fr minmax(0, 0.9fr) minmax(20rem, 0.45fr);
      align-items: start;
    }

    .cta-grid .eyebrow {
      margin: 0;
    }
  }
</style>
