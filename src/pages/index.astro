---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import barberiaDemo from '../assets/demos/barberia-concepto.png';

const title = 'Diseño web para negocios locales en Barcelona | Jordi Sánchez';
const description =
  'Webs rápidas y a medida con reserva online para barberías, peluquerías y centros de estética de Barcelona. Trato directo y precio cerrado.';

const professionalServiceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://www.jordisanchezweb.es/#negocio',
  name: 'Jordi Sánchez Web',
  url: 'https://www.jordisanchezweb.es/',
  image: 'https://www.jordisanchezweb.es/og-image.png',
  email: 'jordigw@gmail.com',
  founder: {
    '@type': 'Person',
    name: 'Jordi Sánchez',
  },
  areaServed: {
    '@type': 'City',
    name: 'Barcelona',
  },
  priceRange: 'Precio cerrado',
  knowsLanguage: ['es', 'ca'],
  sameAs: ['https://jordi-sanchez-portafolio.vercel.app/'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de diseño web para negocios locales',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Diseño y desarrollo web a medida',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Integración de reservas online',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'SEO local para negocios de Barcelona',
        },
      },
    ],
  },
};

const problems = [
  {
    title: 'No te encuentran en Google',
    text: 'Cuando alguien busca una barbería o peluquería cerca, tu competencia aparece antes.',
  },
  {
    title: 'Las reservas todavía van a mano',
    text: 'Mensajes, llamadas y huecos que cuadrar mientras intentas atender a quien ya está en el local.',
  },
  {
    title: 'Tu web falla en el móvil',
    text: 'Carga lenta, textos diminutos o botones que cuesta pulsar justo donde llegan casi todos tus clientes.',
  },
  {
    title: 'Tu escaparate es solo un Linktree',
    text: 'Sirve para ordenar enlaces, pero no para explicar por qué deberían elegirte ni para posicionarte.',
  },
];

const services = [
  {
    number: '01',
    title: 'Una web a tu medida',
    text: 'Diseñada alrededor de tu negocio, tus servicios y tu forma de trabajar. Sin apariencia de plantilla.',
  },
  {
    number: '02',
    title: 'Reservas online, 24 h',
    text: 'Integro un sistema sencillo para que tus clientes reserven sin llamarte ni esperar una respuesta.',
  },
  {
    number: '03',
    title: 'Que Google te encuentre',
    text: 'La dejo rápida, bien estructurada y preparada para competir en búsquedas locales relevantes.',
  },
];

const process = [
  {
    number: '1',
    title: 'Hablamos',
    text: 'Me cuentas cómo funciona tu negocio y qué necesitas. Sin reuniones eternas ni jerga técnica.',
  },
  {
    number: '2',
    title: 'La monto',
    text: 'Diseño, escribo y construyo la web. Te enseño el avance y afinamos juntos los últimos detalles.',
  },
  {
    number: '3',
    title: 'Online',
    text: 'La publico, conecto las reservas y te explico lo necesario para que puedas usarla con tranquilidad.',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={professionalServiceJsonLd}>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Diseño web · Barcelona</p>
      <h1>Tu negocio ya funciona. Que su presencia online esté a la altura.</h1>

      <div class="hero-bottom">
        <p class="hero-index" aria-hidden="true">01—25</p>
        <div class="hero-copy">
          <p class="lede">
            Soy Jordi. Creo webs sencillas con reserva online para barberías, peluquerías y centros de estética. Trato directo, sin intermediarios y con precio cerrado.
          </p>
          <a class="button button--accent" href="#contacto">
            Cuéntame tu proyecto <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section problems" aria-labelledby="problema-title">
    <div class="container problem-grid">
      <header class="problem-intro">
        <p class="eyebrow">El problema</p>
        <h2 id="problema-title">Tu negocio abre cada día. Tu web también debería.</h2>
      </header>

      <ol class="problem-list">
        {problems.map((problem, index) => (
          <li>
            <span class="list-number">0{index + 1}</span>
            <div>
              <h3>{problem.title}</h3>
              <p>{problem.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section services" aria-labelledby="servicios-title">
    <div class="container">
      <SectionHeading
        id="servicios-title"
        eyebrow="Lo que hago"
        title="Una web que te quite trabajo, no que te dé más."
        description="Lo esencial para que un negocio local se vea profesional, reciba reservas y pueda crecer sin complicaciones."
      />

      <ol class="service-list">
        {services.map((service) => (
          <li>
            <p class="service-number" aria-hidden="true">{service.number}</p>
            <div>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section featured-demo" aria-labelledby="featured-demo-title">
    <div class="container featured-demo-grid">
      <div class="featured-demo-copy">
        <p class="eyebrow">Concepto interactivo</p>
        <h2 id="featured-demo-title">Una barbería ficticia. Una web que sí puedes recorrer.</h2>
        <p class="lede">
          Taller 33 es una demostración creada para enseñar cómo podrían presentarse los servicios, horarios y reservas de una barbería real.
        </p>
        <div class="featured-demo-actions">
          <a class="button button--accent" href="/demos/taller-33/">Explorar la demo</a>
          <a class="text-link" href="/ejemplos/">Ver todos los conceptos</a>
        </div>
      </div>

      <a
        class="featured-demo-preview"
        href="/demos/taller-33/"
        aria-label="Abrir la demo interactiva de Taller 33"
      >
        <figure>
          <Image
            src={barberiaDemo}
            alt="Portada del concepto ficticio de barbería Taller 33"
            widths={[560, 840, 1200]}
            sizes="(min-width: 52rem) 48vw, 100vw"
            format="webp"
            quality={86}
            loading="lazy"
          />
          <figcaption>Demo navegable <span aria-hidden="true">↗</span></figcaption>
        </figure>
      </a>
    </div>
  </section>

  <section class="section process" aria-labelledby="proceso-title">
    <div class="container">
      <SectionHeading
        id="proceso-title"
        eyebrow="Cómo trabajo"
        title="De la primera charla a una web publicada."
        description="Un proceso corto y claro. Tú sigues atendiendo tu negocio; yo me encargo de que la web avance."
      />

      <ol class="process-list">
        {process.map((step) => (
          <li>
            <span class="process-number" aria-hidden="true">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section about" aria-labelledby="about-title">
    <div class="container about-grid">
      <div class="about-statement">
        <p class="eyebrow">Por qué conmigo</p>
        <h2 id="about-title">Trabajas conmigo, no con una agencia.</h2>
        <p class="lede">
          La persona con la que hablas es la misma que piensa, diseña y construye tu web. Eso hace el proceso más ágil y el resultado más tuyo.
        </p>
        <a
          class="text-link"
          href="https://jordi-sanchez-portafolio.vercel.app/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Ver mi portafolio técnico
        </a>
      </div>

      <dl class="facts">
        <div>
          <dt><span aria-hidden="true">+</span>3</dt>
          <dd>Años desarrollando productos web</dd>
        </div>
        <div>
          <dt>100<span aria-hidden="true">%</span></dt>
          <dd>Trato directo conmigo</dd>
        </div>
        <div>
          <dt>1</dt>
          <dd>Precio cerrado desde el principio</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="contact" id="contacto" aria-labelledby="contact-form-title">
    <div class="container contact-grid">
      <div class="contact-copy">
        <p class="eyebrow">Hablemos</p>
        <h2 id="contact-form-title">¿Tu negocio necesita una web mejor?</h2>
        <p>
          Cuéntame en qué punto estás. Te responderé personalmente para ver si puedo ayudarte, sin compromiso.
        </p>
        <a href="mailto:jordigw@gmail.com">jordigw@gmail.com</a>
      </div>

      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    overflow: hidden;
  }

  .hero-inner {
    padding-block: clamp(4.5rem, 10vw, 9rem) clamp(4rem, 8vw, 7rem);
  }

  .hero h1 {
    max-width: 11.2ch;
  }

  .hero h1::first-line {
    font-style: italic;
  }

  .hero-bottom {
    display: grid;
    gap: 2rem;
    margin-top: clamp(3rem, 7vw, 7rem);
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }

  .hero-index {
    color: var(--muted);
    font-family: var(--serif);
    font-size: 0.92rem;
    font-variant-numeric: tabular-nums;
  }

  .hero-copy {
    display: grid;
    gap: 2rem;
  }

  .hero-copy .button {
    justify-self: start;
  }

  .problem-grid {
    display: grid;
    gap: clamp(3rem, 8vw, 8rem);
  }

  .problem-intro h2 {
    max-width: 9.5ch;
    font-size: clamp(2.8rem, 6.5vw, 6.3rem);
  }

  .problem-list,
  .service-list,
  .process-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .problem-list {
    border-top: 1px solid var(--line);
  }

  .problem-list li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 1.25rem;
    padding-block: 1.7rem;
    border-bottom: 1px solid var(--line);
  }

  .list-number {
    padding-top: 0.25rem;
    color: var(--accent);
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .problem-list h3 {
    font-family: var(--sans);
    font-size: clamp(1.12rem, 2vw, 1.35rem);
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  .problem-list p {
    max-width: 39rem;
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .services {
    background: #f0ece4;
  }

  .featured-demo {
    background: var(--ink);
    color: #f7f4ee;
  }

  .featured-demo-grid {
    display: grid;
    gap: clamp(3.5rem, 8vw, 7rem);
  }

  .featured-demo-copy {
    align-self: center;
  }

  .featured-demo-copy .eyebrow {
    color: #c77b6d;
  }

  .featured-demo-copy h2 {
    max-width: 10ch;
    font-size: clamp(3rem, 6.5vw, 6rem);
  }

  .featured-demo-copy .lede {
    max-width: 35rem;
    margin-top: 2rem;
    color: #aaa197;
  }

  .featured-demo-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2rem;
    align-items: center;
    margin-top: 2.5rem;
  }

  .featured-demo-actions .text-link {
    color: #f7f4ee;
  }

  .featured-demo-preview {
    display: block;
    align-self: center;
    text-decoration: none;
  }

  .featured-demo-preview figure {
    position: relative;
    margin: 0;
    overflow: hidden;
    border: 1px solid #39342d;
    background: #2b2620;
  }

  .featured-demo-preview :global(img) {
    width: 100%;
    height: auto;
    opacity: 0.94;
    transition: transform 420ms cubic-bezier(0.2, 0.75, 0.25, 1), opacity 180ms ease;
  }

  .featured-demo-preview figcaption {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    padding: 0.75rem 0.9rem;
    background: #f7f4ee;
    color: var(--ink);
    font-size: 0.67rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .featured-demo-preview:hover :global(img) {
    opacity: 1;
    transform: scale(1.015);
  }

  .service-list {
    border-top: 1px solid var(--ink);
  }

  .service-list li {
    display: grid;
    gap: 1.5rem;
    padding-block: clamp(2rem, 5vw, 3.8rem);
    border-bottom: 1px solid var(--line);
  }

  .service-number {
    color: var(--accent);
    font-family: var(--serif);
    font-size: clamp(3.3rem, 7vw, 6.5rem);
    font-weight: 430;
    line-height: 0.75;
    letter-spacing: -0.06em;
  }

  .service-list h3 {
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .service-list li > div > p {
    max-width: 37rem;
    margin-top: 1rem;
    color: var(--muted);
  }

  .process-list {
    counter-reset: step;
    border-top: 1px solid var(--line);
  }

  .process-list li {
    position: relative;
    display: grid;
    gap: 1rem;
    padding-block: 2rem;
    border-bottom: 1px solid var(--line);
  }

  .process-number {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    place-items: center;
    border: 1px solid var(--accent);
    border-radius: 50%;
    color: var(--accent);
    font-family: var(--serif);
    font-size: 1.35rem;
  }

  .process-list h3 {
    font-size: clamp(2.1rem, 5vw, 4.2rem);
  }

  .process-list p {
    max-width: 31rem;
    color: var(--muted);
  }

  .about-grid {
    display: grid;
    gap: clamp(4rem, 10vw, 9rem);
  }

  .about-statement h2 {
    max-width: 10ch;
  }

  .about-statement .lede {
    margin-top: 2rem;
  }

  .about-statement .text-link {
    margin-top: 2.5rem;
  }

  .facts {
    margin: 0;
    border-top: 1px solid var(--ink);
  }

  .facts div {
    padding-block: 2rem;
    border-bottom: 1px solid var(--line);
  }

  .facts dt {
    font-family: var(--serif);
    font-size: clamp(4rem, 8vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .facts dt span {
    color: var(--accent);
  }

  .facts dd {
    max-width: 17rem;
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 650;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .contact {
    padding-block: var(--section-space);
    background: var(--ink);
    color: #f7f4ee;
  }

  .contact-grid {
    display: grid;
    gap: clamp(4rem, 10vw, 9rem);
  }

  .contact .eyebrow {
    color: #c77b6d;
  }

  .contact h2 {
    max-width: 10ch;
    font-size: clamp(3rem, 7vw, 6.5rem);
  }

  .contact-copy > p:not(.eyebrow) {
    max-width: 32rem;
    margin-top: 2rem;
    color: #aaa197;
    font-size: 1.05rem;
  }

  .contact-copy > a {
    display: inline-block;
    margin-top: 2rem;
    color: #f7f4ee;
    font-size: clamp(0.95rem, 2vw, 1.2rem);
  }

  @media (min-width: 52rem) {
    .hero-bottom {
      grid-template-columns: minmax(8rem, 0.4fr) minmax(0, 0.6fr);
    }

    .hero-copy {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .hero-copy .button {
      justify-self: end;
    }

    .problem-grid {
      grid-template-columns: minmax(0, 0.85fr) minmax(28rem, 1.15fr);
      align-items: start;
    }

    .problem-intro {
      position: sticky;
      top: 3rem;
    }

    .service-list li {
      grid-template-columns: minmax(8rem, 0.35fr) minmax(0, 0.65fr);
      align-items: start;
    }

    .featured-demo-grid {
      grid-template-columns: minmax(22rem, 0.75fr) minmax(0, 1.25fr);
      align-items: center;
    }

    .process-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-bottom: 1px solid var(--line);
    }

    .process-list li {
      min-height: 25rem;
      padding: 2rem;
      border-right: 1px solid var(--line);
      border-bottom: 0;
    }

    .process-list li:first-child {
      padding-left: 0;
    }

    .process-list li:last-child {
      padding-right: 0;
      border-right: 0;
    }

    .process-list h3 {
      align-self: end;
    }

    .about-grid,
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(26rem, 0.8fr);
      align-items: start;
    }
  }
</style>
