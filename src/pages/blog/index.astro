---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---

<BaseLayout
  title="Consejos de web y reservas para negocios locales | Blog"
  description="Guías claras sobre páginas web, reservas online y SEO local para barberías, peluquerías y centros de estética de Barcelona."
  canonicalPath="/blog/"
>
  <header class="page-intro container">
    <p class="eyebrow">Notas de trabajo</p>
    <h1>Web, reservas y negocio local. Sin rodeos.</h1>
    <div class="page-intro__footer">
      <p class="lede">
        Respuestas prácticas a las preguntas que aparecen antes de montar una web: cuánto cuesta, qué sistema de reservas elegir y qué necesita Google para encontrarte.
      </p>
      <p class="meta-line"><span>{posts.length} artículos</span><span>Barcelona</span></p>
    </div>
  </header>

  <section class="posts-section" aria-labelledby="posts-title">
    <div class="container">
      <h2 id="posts-title" class="visually-hidden">Todos los artículos</h2>
      <ol class="post-list">
        {posts.map((post, index) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <div class="post-index">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <span>{post.data.category}</span>
              </div>
              <div class="post-main">
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </div>
              <div class="post-date">
                <time datetime={post.data.publishDate.toISOString()}>
                  {dateFormatter.format(post.data.publishDate)}
                </time>
                <span aria-hidden="true">↗</span>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .posts-section {
    padding-bottom: var(--section-space);
    border-top: 1px solid var(--line);
  }

  .post-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-list li {
    border-bottom: 1px solid var(--line);
  }

  .post-list a {
    display: grid;
    gap: 1.75rem;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
    text-decoration: none;
  }

  .post-index,
  .post-date {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .post-index span:first-child {
    color: var(--accent);
  }

  .post-main h2 {
    max-width: 15ch;
    font-size: clamp(2rem, 4.5vw, 3.8rem);
    line-height: 1.02;
    transition: color 180ms ease;
  }

  .post-main p {
    max-width: 40rem;
    margin-top: 1rem;
    color: var(--muted);
  }

  .post-date span {
    color: var(--accent);
    font-size: 1rem;
    transition: transform 180ms ease;
  }

  .post-list a:hover h2 {
    color: var(--accent);
  }

  .post-list a:hover .post-date span {
    transform: translate(0.2rem, -0.2rem);
  }

  @media (min-width: 52rem) {
    .post-list a {
      grid-template-columns: minmax(9rem, 0.23fr) minmax(0, 0.57fr) minmax(9rem, 0.2fr);
      align-items: start;
    }

    .post-index {
      display: grid;
      justify-content: initial;
      gap: 1.2rem;
    }

    .post-date {
      justify-content: flex-end;
    }
  }
</style>
