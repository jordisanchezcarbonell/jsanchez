---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const canonicalPath = `/blog/${post.id}/`;
const publishedTime = post.data.publishDate.toISOString();
const modifiedTime = post.data.updatedDate?.toISOString();
const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  image: 'https://www.jordisanchezweb.es/og-image.png',
  datePublished: publishedTime,
  dateModified: modifiedTime ?? publishedTime,
  mainEntityOfPage: `https://www.jordisanchezweb.es${canonicalPath}`,
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: 'https://www.jordisanchezweb.es/',
  },
  publisher: {
    '@type': 'Person',
    name: 'Jordi Sánchez',
    url: 'https://www.jordisanchezweb.es/',
  },
  inLanguage: 'es-ES',
};
---

<BaseLayout
  title={`${post.data.title} | Jordi Sánchez`}
  description={post.data.description}
  canonicalPath={canonicalPath}
  type="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  jsonLd={articleJsonLd}
>
  <article>
    <header class="article-header container">
      <nav aria-label="Migas de pan">
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{post.data.category}</span>
      </nav>

      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>

      <div class="article-meta">
        <p>Por {post.data.author}</p>
        <time datetime={publishedTime}>{dateFormatter.format(post.data.publishDate)}</time>
        {post.data.updatedDate && (
          <p>Actualizado el {dateFormatter.format(post.data.updatedDate)}</p>
        )}
      </div>
    </header>

    <div class="article-body container">
      <div class="article-aside" aria-hidden="true">
        <span>Lectura</span>
        <span>↓</span>
      </div>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

  <aside class="article-cta" aria-labelledby="article-cta-title">
    <div class="container article-cta__inner">
      <div>
        <p class="eyebrow">¿Lo aplicamos?</p>
        <h2 id="article-cta-title">Hablemos de la web de tu negocio.</h2>
      </div>
      <div>
        <p>
          Si quieres una web rápida, clara y preparada para recibir reservas, cuéntame en qué punto estás.
        </p>
        <a class="button button--accent" href="/#contacto">Contactar con Jordi</a>
      </div>
    </div>
  </aside>
</BaseLayout>

<style>
  .article-header {
    padding-block: clamp(4rem, 9vw, 8rem) clamp(3.5rem, 7vw, 6rem);
  }

  .article-header nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: clamp(3rem, 7vw, 6rem);
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .article-header h1 {
    max-width: 12ch;
    font-size: clamp(3.1rem, 8vw, 7rem);
  }

  .article-description {
    max-width: 45rem;
    margin-top: 2rem;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.55;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
    margin-top: clamp(2.5rem, 6vw, 5rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .article-body {
    display: grid;
    gap: 2rem;
    padding-block: clamp(4rem, 9vw, 8rem);
    border-top: 1px solid var(--line);
  }

  .article-aside {
    display: none;
  }

  .article-cta {
    padding-block: var(--section-space);
    border-top: 1px solid var(--line);
    background: #eee9e0;
  }

  .article-cta__inner {
    display: grid;
    gap: 2.5rem;
  }

  .article-cta h2 {
    max-width: 10ch;
    font-size: clamp(2.7rem, 6vw, 5rem);
  }

  .article-cta__inner > div:last-child > p {
    max-width: 31rem;
    color: var(--muted);
  }

  .article-cta .button {
    margin-top: 2rem;
  }

  @media (min-width: 52rem) {
    .article-body {
      grid-template-columns: minmax(10rem, 0.35fr) minmax(0, 0.65fr);
    }

    .article-aside {
      display: flex;
      height: max-content;
      justify-content: space-between;
      padding-right: 2rem;
      color: var(--muted);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .article-cta__inner {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.55fr);
      align-items: end;
    }
  }
</style>
