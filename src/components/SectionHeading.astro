---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  id?: string;
}

const { eyebrow, title, description, id } = Astro.props;
---

<header class="section-heading">
  <p class="eyebrow">{eyebrow}</p>
  <div class="heading-grid">
    <h2 id={id}>{title}</h2>
    {description && <p>{description}</p>}
  </div>
</header>

<style>
  .section-heading {
    margin-bottom: clamp(3rem, 7vw, 6rem);
  }

  .heading-grid {
    display: grid;
    gap: 1.5rem;
  }

  h2 {
    max-width: 12ch;
  }

  .heading-grid p {
    max-width: 32rem;
    color: var(--muted);
    font-size: 1.05rem;
  }

  @media (min-width: 52rem) {
    .heading-grid {
      grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
      align-items: end;
    }

    .heading-grid p {
      justify-self: end;
    }
  }
</style>
